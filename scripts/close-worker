#!/usr/bin/env bash
# close-worker <name> — kill the pane for the named worker in the current window
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_lib.sh"

name="${1:-}"
if [[ -z "$name" ]]; then
  echo "Usage: close-worker <name>" >&2
  exit 1
fi

pane=$(_ma_get_pane_id_by_worker_name "$name")
if [[ -z "$pane" ]]; then
  echo "Error: no worker named '$name' found in the current window." >&2
  exit 1
fi

tmux kill-pane -t "$pane"
echo "Closed worker '$name' (pane $pane)"
