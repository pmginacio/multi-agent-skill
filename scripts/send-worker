#!/usr/bin/env bash
# send-worker <name> <message...> — send a message to a named worker in the current window
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_lib.sh"

name="${1:-}"
shift || true
message="$*"

if [[ -z "$name" || -z "$message" ]]; then
  echo "Usage: send-worker <name> <message>" >&2
  exit 1
fi

pane=$(_ma_get_pane_id_by_worker_name "$name")
if [[ -z "$pane" ]]; then
  echo "Error: no worker named '$name' found in the current window." >&2
  exit 1
fi

tmux send-keys -t "$pane" "$message"
sleep 0.1
tmux send-keys -t "$pane" Enter
echo "Sent to '$name' (pane $pane): $message"
