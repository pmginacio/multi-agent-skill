#!/usr/bin/env bash
# watch-workers — background daemon that tracks worker pane activity by comparing
# captured pane content between polls. Transitions workers between active and
# waiting states. Started by spawn-workers; killed by close-workers.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_lib.sh"

cleanup() {
    local settings=".claude/settings.local.json"
    local mark_idle="$HOME/.claude/scripts/multi-agent/mark-idle"
    if [[ -f "$settings" ]]; then
        local tmp
        tmp=$(mktemp)
        jq --arg cmd "$mark_idle" '
            .hooks.Stop = ((.hooks.Stop // []) | map(select(
                (.hooks // [] | map(select(.command == $cmd)) | length) == 0
            )))
        ' "$settings" > "$tmp" && mv "$tmp" "$settings"
    fi
}
trap cleanup EXIT

session_name=$(tmux display-message -p '#{session_name}' 2>/dev/null)

POLL_INTERVAL=2   # seconds between checks
WAIT_THRESHOLD=15 # seconds of unchanged pane content before marking a worker as waiting

state_dir=$(_ma_state_dir)
mkdir -p "$state_dir"
echo $$ > "$state_dir/watcher.pid"

while true; do
  sleep "$POLL_INTERVAL"

  if ! tmux has-session -t "$session_name" 2>/dev/null; then
    exit 0
  fi

  while IFS=' ' read -r pane_id name; do
    [[ "$name" == "Simon" ]] && continue

    state=$(_ma_get_state "$name")
    [[ "$state" == "idle" ]] && continue

    current_hash=$(tmux capture-pane -t "$pane_id" -p 2>/dev/null | md5) || continue
    now=$(date +%s)

    state_file="$state_dir/${name}.${state}"
    prev_hash=$(cat "$state_file" 2>/dev/null || true)

    if [[ "$current_hash" != "$prev_hash" ]]; then
      # Content changed — write new hash into state file (also updates mtime)
      echo "$current_hash" > "$state_file"
      if [[ "$state" == "waiting" ]]; then
        _ma_set_state "$name" "active"
      fi
    else
      # Content unchanged — use state file mtime as last-changed timestamp
      last_changed=$(stat -f %m "$state_file" 2>/dev/null || echo "$now")
      elapsed=$(( now - last_changed ))
      if [[ "$state" == "active" ]] && (( elapsed > WAIT_THRESHOLD )); then
        _ma_set_state "$name" "waiting"
        "$SCRIPT_DIR/bring-focus"
      fi
    fi
  done < <(_ma_list_worker_panes)
done
