#!/usr/bin/env bash
# close-workers — kill all worker panes in the current window
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_lib.sh"

killed=0
while IFS=' ' read -r pane_id name; do
  [[ "$name" == "Simon" ]] && continue
  tmux kill-pane -t "$pane_id" 2>/dev/null && echo "Closed '$name' (pane $pane_id)" && ((killed++)) || true
done < <(_ma_list_worker_panes)

echo "Closed $killed worker pane(s)."
