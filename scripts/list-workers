#!/usr/bin/env bash
# list-workers — list all worker panes in the current window (identified by @worker-name)
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_lib.sh"

found=0
while IFS=' ' read -r pane_id name; do
  printf "%-12s %s\n" "$name" "$pane_id"
  ((found++)) || true
done < <(_ma_list_worker_panes)

if [[ $found -eq 0 ]]; then
  echo "No workers found."
fi
